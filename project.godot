; Engine configuration file.
; Godot 4.x  —  RAMEN-YA / らーめん屋  2D pixel ramen-shop management demo

config_version=5

[application]

config/name="RAMEN-YA"
config/description="A 2D pixel-art ramen-shop management game demo."
run/main_scene="res://scenes/World.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Music="*res://scripts/Music.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/dpi/allow_hidpi=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.137255, 0.121569, 0.156863, 1)

[input_devices]

pointing/emulate_touch_from_mouse=true
